# Waitlist form endpoint. Copy this file to `.env` and paste your real endpoint.
# Works with any service that accepts a POST with JSON { "email": "..." }:
#   - Formspree:   https://formspree.io/f/xxxxxxx
#   - Buttondown, Mailchimp, or your own API also work.
# If left unset, signups are saved in the visitor's browser (localStorage)
# so the form still functions during the placeholder phase.
VITE_WAITLIST_ENDPOINT=
